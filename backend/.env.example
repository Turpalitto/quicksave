PORT=3000
NODE_ENV=development
REDIS_URL=
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000
RESOLVE_DEADLINE_MS=45000
CACHE_TTL_MS=600000
ALLOWED_ORIGINS=
# Production: set comma-separated origins (e.g. https://quicksave.app). Empty = allow all (dev only).
METRICS_TOKEN=
LOG_LEVEL=info
# Optional: browser cookies for Instagram (export from Chrome DevTools → Application → Cookies)
# Format: sessionid=XXX; csrftoken=YYY; ds_user_id=ZZZ
INSTAGRAM_COOKIES=
# Router blocks instagram.com DNS? Leave enabled (default). Set 0 to use system DNS only.
USE_PUBLIC_DNS=1
INSTAGRAM_DNS_SERVERS=8.8.8.8,1.1.1.1,8.8.4.4
