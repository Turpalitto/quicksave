PORT=3000
NODE_ENV=production
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
REQUEST_TIMEOUT_MS=15000
RESOLVE_DEADLINE_MS=25000
CACHE_TTL_MS=600000
CACHE_MAX_ENTRIES=500
# CACHE_REDIS=0
UPSTREAM_POOL_SIZE=3
# REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
SERVICE_VERSION=1.1.0

# Metrics: protected by default in production
# METRICS_PUBLIC=true
# METRICS_TOKEN=your-secret-token

# Optional Play purchase verification (POST /billing/play/verify)
# BILLING_PLAY_VERIFY=1
# BILLING_DEV_ACCEPT=1
