{
  "name": "quicksave-backend",
  "version": "1.5.0",
  "description": "QuickSave backend — resolves public Instagram post URLs.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint src --ext .js",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "smoke:deploy": "node ../scripts/smoke-deploy.mjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "axios": "^1.6.8",
    "express-rate-limit": "^7.2.0",
    "rate-limit-redis": "^4.2.0",
    "redis": "^6.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
